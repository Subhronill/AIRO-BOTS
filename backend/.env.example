# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (development)
DATABASE_URL="file:./prisma/dev.db"

# PostgreSQL (production) — uncomment and fill in
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/airo_bots"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_A_STRONG_RANDOM_SECRET"
JWT_REFRESH_SECRET="REPLACE_WITH_A_DIFFERENT_STRONG_RANDOM_SECRET"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
