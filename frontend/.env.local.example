# ─── Backend API ─────────────────────────────────────────────────────────────
# Development — uses Next.js rewrite proxy (/api/* → localhost:4000/api/*)
# Works automatically from both localhost and phone on the same Wi-Fi.
NEXT_PUBLIC_API_URL=/api

# Optional: override backend target for the rewrite proxy
# BACKEND_URL=http://localhost:4000

# Production — replace with your deployed backend URL
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
